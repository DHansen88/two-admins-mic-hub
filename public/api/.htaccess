# Protect API directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Handle CORS preflight requests
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
    
    # Ensure PHP files are processed
    RewriteRule ^(.*)$ - [L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Deny access to config.php directly (only allow inclusion)
<Files "config.php">
    # Allow PHP to include it but add security note
    # The file should check for a defined constant in production
</Files>

# Deny access to setup.php after initial setup
# Uncomment after running setup:
# <Files "setup.php">
#     Deny from all
# </Files>
